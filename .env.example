# ============================================================
# COMPETITOR INTELLIGENCE — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================================

# LLM (required)
GROQ_API_KEY=your_groq_api_key_here          # https://console.groq.com (free)

# YouTube (optional — enables full video stats)
YOUTUBE_API_KEY=your_youtube_api_key_here    # https://console.cloud.google.com (free)

# Meta Ads (optional — enables official Ad Library API)
META_ACCESS_TOKEN=your_meta_token_here       # https://developers.facebook.com/tools/accesstoken/

# SerpAPI (optional — enables Google search intelligence)
SERPAPI_KEY=your_serpapi_key_here            # https://serpapi.com (100 free/mo)

# Email alerts (optional)
ALERT_EMAIL_FROM=you@gmail.com
ALERT_EMAIL_TO=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password        # Gmail App Password (not your main password)

# Slack alerts (optional)
SLACK_WEBHOOK_URL=

# MLflow / DagsHub (optional — enables experiment tracking)
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_REPO_NAME=your_repo_name
DAGSHUB_TOKEN=your_dagshub_token
MLFLOW_EXPERIMENT_NAME=competitor-intelligence

# Grafana (only needed if you enable Grafana in docker-compose.yml)
GRAFANA_ADMIN_PASSWORD=changeme_use_strong_password

# App
APP_ENV=production
SECRET_KEY=change_this_to_a_random_string_at_least_32_chars

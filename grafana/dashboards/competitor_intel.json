{
  "title": "Competitor Intelligence",
  "uid": "competitor-intel-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "API Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(http_requests_total[5m])",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null}] }, "unit": "reqps" } }
    },
    {
      "id": 2, "type": "stat", "title": "P95 Latency",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":3}] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
        "legendFormat": "errors/s"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":0.1}] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Active Connections",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "http_requests_total",
        "legendFormat": "total"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"blue","value":null}] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(http_requests_total[1m])",
        "legendFormat": "{{method}} {{handler}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Request Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.90, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p90" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7, "type": "gauge", "title": "API Health Score",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "1 - rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
        "legendFormat": "health"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":0.9},{"color":"green","value":0.99}] } } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Requests by Endpoint",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "topk(5, rate(http_requests_total[5m]))",
        "legendFormat": "{{handler}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } }
    },
    {
      "id": 9, "type": "logs", "title": "Recent Agent Activity (via Prometheus)",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(http_requests_total[1m])",
        "legendFormat": "{{method}} {{handler}} {{status}}"
      }]
    }
  ],
  "tags": ["competitor-intelligence", "monitoring"]
}
